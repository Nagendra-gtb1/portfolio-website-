{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/client" }
    },
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/favicon\\.(ico|png)$",
      "dest": "/favicon.$1",
      "headers": {
        "cache-control": "public, max-age=31536000"
      }
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "/assets/$1"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/index.ts"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/index.ts"
    }
  ]
}