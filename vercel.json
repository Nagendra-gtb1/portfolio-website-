{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/client/server/**"
    }
  },
  "routes": [
    {
      "src": "^/assets/(.*)$",
      "dest": "/assets/$1"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/index.ts"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/index.ts"
    }
  ]
}